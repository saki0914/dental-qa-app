{
  "name": "Dental QA App",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "forwardPorts": [
    3000,
    8080,
    9099,
    9199
  ],
  "portsAttributes": {
    "3000": {
      "label": "Dental QA local server",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Firestore Emulator",
      "onAutoForward": "silent"
    },
    "9099": {
      "label": "Auth Emulator",
      "onAutoForward": "silent"
    },
    "9199": {
      "label": "Storage Emulator",
      "onAutoForward": "silent"
    }
  },
  "mounts": [
    "source=dental-qa-app-codex,target=/home/node/.codex,type=volume"
  ],
  "postCreateCommand": "sudo chown -R node:node /home/node/.codex && chmod 700 /home/node/.codex && git config --global --add safe.directory /workspaces/${localWorkspaceFolderBasename} && npm install && npx playwright install --with-deps chromium webkit",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
